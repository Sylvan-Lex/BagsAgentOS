{
  "name": "bags-agent",
  "version": "1.0.0",
  "description": "Bags CLI Agent - AI Agent for Solana Token Launchpad",
  "author": "Bags Team",
  "bin": {
    "bags": "./bin/run.cjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@oclif/core": "^4.0.0",
    "@oclif/plugin-help": "^6.0.0",
    "chalk": "^5.3.0",
    "conf": "^12.0.0",
    "inquirer": "^10.0.0",
    "ora": "^8.0.0",
    "terminal-image": "^4.2.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.10.0",
    "oclif": "^4.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "keywords": [
    "oclif",
    "bags",
    "cli",
    "agent",
    "solana"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "bags",
    "commands": "./dist/commands"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build && oclif manifest",
    "prepare": "npm run build",
    "dev": "ts-node src/index.ts",
    "postpack": "rm oclif.manifest.json"
  }
